# قاعدة البيانات (استبدل القيم عند النشر)
DATABASE_URL="postgresql://postgres:password@localhost:5432/project_management?schema=public"

# JWT (غيّر إلى مفتاح قوي عند النشر)
JWT_SECRET="your-super-secret-key-change-it"

# عنوان الواجهة الأمامية (لـ CORS)
FRONTEND_URL="http://localhost:5173"

# منفذ الخادم
PORT=5000

# وضع الصيانة
MAINTENANCE_MODE=false

# إعدادات البريد الإلكتروني (اختياري - استخدم بياناتك الحقيقية في ملف .env المحلي فقط)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"